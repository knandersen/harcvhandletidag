{
	"name": "harcvhandletidag",
	"version": "0.0.1",
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260528.1",
		"@eslint/compat": "^2.0.4",
		"@fontsource-variable/inter": "^5.2.8",
		"@lucide/svelte": "^1.3.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.3.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^8.0.7"
	},
	"private": true,
	"scripts": {
		"dev": "vite dev --host",
		"build": "drizzle-kit generate &&vite build",
		"preview": "bun run build && wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"deploy": "bun run build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:migrate:local": "wrangler d1 migrations apply harcvhandlet --local",
		"db:migrate:remote": "wrangler d1 migrations apply harcvhandlet --remote"
	},
	"type": "module",
	"dependencies": {
		"@fontsource/montserrat": "^5.2.8",
		"bits-ui": "^2.18.1",
		"canvas-confetti": "^1.9.4",
		"countup.js": "^2.10.0",
		"drizzle-orm": "^0.45.2",
		"luxon": "^3.7.2",
		"wrangler": "^4.94.0"
	}
}
