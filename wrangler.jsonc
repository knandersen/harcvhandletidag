{
   "$schema": "node_modules/wrangler/config-schema.json",
   "name": "har-cv-handlet-idag",
   "compatibility_date": "2026-05-26",
   "observability": {
     "enabled": true
   },
   "main": ".svelte-kit/cloudflare/_worker.js",
   "assets": {
     "binding": "ASSETS",
     "directory": ".svelte-kit/cloudflare"
   },
   "compatibility_flags": [
     "nodejs_compat"
   ]
 }